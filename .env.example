# ============================================================
# Grão de Solo — variáveis de ambiente
# ============================================================
# Frontend (Vite). Opcionais em dev — o site funciona sem Supabase
# (o formulário de contacto cai para mailto). Obrigatórias em produção.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Edge function `submit-contact` — NÃO vão neste ficheiro.
# Definir como Supabase Secrets (Dashboard → Edge Functions → Secrets):
#   SUPABASE_URL                (já presente por defeito)
#   SUPABASE_SERVICE_ROLE_KEY   (já presente por defeito)
#   RESEND_API_KEY              (opcional — notificação por email)
#   FROM_EMAIL                  (opcional — remetente verificado no Resend)
#   NOTIFY_EMAIL                (opcional — destino; default graodesolo@gmail.com)
# ------------------------------------------------------------
